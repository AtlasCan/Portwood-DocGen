<apex:page showHeader="false" sidebar="false" standardStylesheets="false">
    <script>
        var sessionId = '{!$Api.Session_ID}';
        var parentOrigin = null;
        var pollTimer = null;

        function isSalesforceOrigin(origin) {
            if (!origin) return false;
            return /\.(lightning\.force|salesforce|visualforce|force)\.com$/.test(origin);
        }

        window.addEventListener('message', function(event) {
            if (!event.data || event.data.action !== 'deploy') return;
            if (!isSalesforceOrigin(event.origin)) return;
            parentOrigin = event.origin;
            deployMetadata(event.data.zipBase64);
        });

        function deployMetadata(zipBase64) {
            var envelope =
                '<?xml version="1.0" encoding="utf-8"?>' +
                '<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" ' +
                'xmlns:met="http://soap.sforce.com/2006/04/metadata">' +
                '<soapenv:Header>' +
                '<met:SessionHeader><met:sessionId>' + sessionId + '</met:sessionId></met:SessionHeader>' +
                '</soapenv:Header>' +
                '<soapenv:Body>' +
                '<met:deploy>' +
                '<met:ZipFile>' + zipBase64 + '</met:ZipFile>' +
                '<met:DeployOptions>' +
                '<met:singlePackage>true</met:singlePackage>' +
                '<met:rollbackOnError>true</met:rollbackOnError>' +
                '</met:DeployOptions>' +
                '</met:deploy>' +
                '</soapenv:Body>' +
                '</soapenv:Envelope>';

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/services/Soap/m/65.0', true);
            xhr.setRequestHeader('Content-Type', 'text/xml; charset=utf-8');
            xhr.setRequestHeader('SOAPAction', '""');
            xhr.onload = function() {
                if (xhr.status >= 200 && xhr.status < 300) {
                    var doc = new DOMParser().parseFromString(xhr.responseText, 'text/xml');
                    var idNode = doc.getElementsByTagName('id')[0];
                    if (idNode && idNode.textContent) {
                        pollDeployStatus(idNode.textContent);
                    } else {
                        var faultNode = doc.getElementsByTagName('faultstring')[0];
                        var errMsg = faultNode ? faultNode.textContent : 'No deploy ID returned';
                        sendResult('Failed', errMsg);
                    }
                } else {
                    sendResult('Failed', 'HTTP ' + xhr.status + ': ' + xhr.statusText);
                }
            };
            xhr.onerror = function() {
                sendResult('Failed', 'Network error during metadata deploy');
            };
            xhr.send(envelope);
        }

        function pollDeployStatus(deployId) {
            var envelope =
                '<?xml version="1.0" encoding="utf-8"?>' +
                '<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" ' +
                'xmlns:met="http://soap.sforce.com/2006/04/metadata">' +
                '<soapenv:Header>' +
                '<met:SessionHeader><met:sessionId>' + sessionId + '</met:sessionId></met:SessionHeader>' +
                '</soapenv:Header>' +
                '<soapenv:Body>' +
                '<met:checkDeployStatus>' +
                '<met:asyncProcessId>' + deployId + '</met:asyncProcessId>' +
                '<met:includeDetails>true</met:includeDetails>' +
                '</met:checkDeployStatus>' +
                '</soapenv:Body>' +
                '</soapenv:Envelope>';

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/services/Soap/m/65.0', true);
            xhr.setRequestHeader('Content-Type', 'text/xml; charset=utf-8');
            xhr.setRequestHeader('SOAPAction', '""');
            xhr.onload = function() {
                var doc = new DOMParser().parseFromString(xhr.responseText, 'text/xml');
                var statusNode = doc.getElementsByTagName('status')[0];
                var status = statusNode ? statusNode.textContent : 'Unknown';

                if (status === 'Succeeded') {
                    sendResult('Succeeded', '');
                } else if (status === 'Failed' || status === 'Canceled') {
                    var errorNodes = doc.getElementsByTagName('problem');
                    var errors = [];
                    for (var i = 0; i < errorNodes.length; i++) {
                        errors.push(errorNodes[i].textContent);
                    }
                    var componentFailures = doc.getElementsByTagName('componentFailures');
                    for (var j = 0; j < componentFailures.length; j++) {
                        var prob = componentFailures[j].getElementsByTagName('problem')[0];
                        var fn = componentFailures[j].getElementsByTagName('fullName')[0];
                        if (prob) {
                            errors.push((fn ? fn.textContent + ': ' : '') + prob.textContent);
                        }
                    }
                    sendResult('Failed', errors.join('; ') || 'Deploy failed with no details');
                } else {
                    pollTimer = setTimeout(function() { pollDeployStatus(deployId); }, 2000);
                }
            };
            xhr.onerror = function() {
                sendResult('Failed', 'Network error checking deploy status');
            };
            xhr.send(envelope);
        }

        function sendResult(status, error) {
            if (pollTimer) { clearTimeout(pollTimer); pollTimer = null; }
            if (!parentOrigin) return;
            window.parent.postMessage({
                type: 'provision_result',
                status: status,
                error: error
            }, parentOrigin);
        }
    </script>
</apex:page>
